# =============================================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА (docker compose up — с docker-compose.override.yml)
# Скопируйте в .env: cp .env.example .env
# =============================================================================
DATABASE_URL=sqlite:///./beerpub.db
SECRET_KEY=dev-secret-key

# =============================================================================
# ПРОДАКШЕН (сервер: без docker-compose.override.yml)
# SQLite в Docker volume data/ (см. docker-compose.yml)
# =============================================================================
# DATABASE_URL=sqlite:///./data/beerpub.db
# SECRET_KEY=change-me-to-random-string
