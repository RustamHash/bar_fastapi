# =============================================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА (docker compose up — с docker-compose.override.yml)
# Скопируйте в .env: cp .env.example .env
# =============================================================================
POSTGRES_USER=beerpub
POSTGRES_PASSWORD=beerpub123
POSTGRES_DB=beerpub
DATABASE_URL=postgresql://beerpub:beerpub123@db:5432/beerpub
SECRET_KEY=beerpub-secret-key-change-in-production

# =============================================================================
# ПРОДАКШЕН (сервер: PostgreSQL на хосте, без docker-compose.override.yml)
# DATABASE_URL указывает на IP хоста из Docker-сети (обычно 172.17.0.1)
# =============================================================================
# DB_HOST=172.17.0.1
# DB_PORT=5432
# DB_NAME=beerpub
# DB_USER=beerpub
# DB_PASSWORD=change-me
# DATABASE_URL=postgresql://beerpub:change-me@172.17.0.1:5432/beerpub
# SECRET_KEY=change-me-to-random-string
